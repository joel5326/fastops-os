{
  "name": "fastops-os",
  "version": "0.1.0",
  "description": "FastOps OS — Multi-Model AI Orchestration Engine",
  "private": true,
  "type": "module",
  "bin": {
    "fastops": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/server/index.ts",
    "start": "node dist/server/index.js",
    "fastops": "tsx src/cli.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "ui:dev": "cd fastops-ui && npm run dev",
    "ui:build": "cd fastops-ui && npm run build"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "author": "Joel Beam & Paul Thoma",
  "license": "UNLICENSED",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.80.0",
    "@google/genai": "^1.46.0",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "openai": "^6.32.0",
    "ws": "^8.19.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^25.5.0",
    "@types/ws": "^8.18.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  }
}
