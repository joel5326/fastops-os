# FastOps OS — Environment Configuration
# Copy to .env and fill in your keys

# Model Provider API Keys (Direct Mode)
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-proj-...
GEMINI_API_KEY=AIza...
OPENROUTER_API_KEY=sk-or-...

# Optional providers (add when available)
# MISTRAL_API_KEY=
# XAI_API_KEY=
# MOONSHOT_API_KEY=

# Cloud-Hosted / Enterprise (uncomment when ready)
# AZURE_OPENAI_ENDPOINT=https://your-instance.openai.azure.com
# AZURE_OPENAI_API_KEY=
# AWS_PROFILE=fastops
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json

# Engine Configuration
FASTOPS_PORT=3100
FASTOPS_SECURITY_TIER=development
# FASTOPS_SECURITY_TIER=enterprise
